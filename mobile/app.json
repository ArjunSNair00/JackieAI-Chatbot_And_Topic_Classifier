{
  "expo": {
    "name": "Jackie AI",
    "slug": "title-generator-mobile",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "extra": {
      "apiBaseUrl": "https://topic-classifier-ai.onrender.com",
      "eas": {
        "projectId": "9a792689-1459-439a-9e2c-2b96401faa91"
      }
    },
    "android": {
      "package": "com.titlegenerator.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "ios": {
      "bundleIdentifier": "com.titlegenerator.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": ["expo-asset", "expo-font"],
    "owner": "arjun_s_nair"
  }
}
